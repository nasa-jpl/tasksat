


tasknet MyRobot {
  end = 100;

  timelines {
    battery : rate [0.0, 100.0] bounds [0.0, 100.0] = 50.0;
    location : state(home, target) = home;
  }

  task charge {
    id 1;
    duration 20;

    pre {
      location = home;
      battery in [0.0, 80.0];
    }

    impacts {
      maint {
        battery +~ 2.0;  
      }
    }
  }

  task drive {
    id 2;
    duration 30;

    pre {
      battery in [30.0, 100.0];  
    }

    impacts {
      pre {
        location = target;
      }
      maint {
        battery +~ -1.0;  
      }
    }
  }

  constraints {
    prop battery_safe: always (battery >= 0.0);
  }
}
