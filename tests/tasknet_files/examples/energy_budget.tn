



tasknet EnergyBudget {
  end = 100;

  timelines {
    battery : rate [-10.0, 5.0] bounds [0.0, 100.0] = 50.0;
  }

  task charge {
    id 1;
    duration 30;
    impacts {
      maint { battery +~ 2.0; }  
    }
  }

  task drive {
    id 2;
    duration 40;
    pre { battery in [40.0, 100.0]; }  
    impacts {
      maint { battery +~ -1.0; }  
    }
  }

  constraints {
    prop safe: always (battery >= 0.0);
    prop must_drive: eventually active(drive);
  }
}
