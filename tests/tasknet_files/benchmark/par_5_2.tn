# Generated by: python tools/generate_benchmark.py --output tests/tasknet_files/benchmark/par_5_2.tn parallel --tasks 5 --timelines 2
#
# Parallel Resource Benchmark (Concurrency Counters)
# 
# Configuration:
# - 5 tasks
# - 2 timelines (concurrency counters)
# - Max parallelism per timeline: 3 concurrent tasks
# - Time horizon: 200
# 
# Design pattern - Concurrency counter:
# - Each timeline is a counter (cumulative timeline, starts at 0)
# - Tasks on that timeline:
#   - pre: counter <= 2 (can start if < 3 tasks running)
#   - inv: counter <= 3 (allows incrementing during task)
#   - impacts.pre: counter += 1 (increment on task start)
#   - impacts.post: counter -= 1 (decrement on task end)
# 
# Task distribution:
# - Tasks distributed round-robin across 2 timelines
# - T1→tl1, T2→tl2, ..., T2→tl2
# - T3→tl1, T4→tl2, ...
# - ~3 tasks per timeline average
# 
# Guaranteed parallelism:
# - Each timeline allows up to 3 concurrent tasks
# - With 2 timelines: up to 6 tasks can run simultaneously
# - Tasks on different timelines are completely independent
# 
# Example execution:
# - Initially: tl1=0, tl2=0, ...
# - T1 starts: tl1=0 ✓ (≤2), tl1 becomes 1
# - T2 starts: tl2=0 ✓, tl2 becomes 1
# - T3 starts: tl1=1 ✓, tl1 becomes 2
# - T5 starts: tl1=2 ✓, tl1 becomes 3 (max reached)
# - Next task on tl1 must wait until one finishes
# 
# Expected behavior:
# - SAT (valid schedule exists)
# - Parallelism is predictable and verifiable
# - Should solve much faster than equivalent sequential chain

tasknet ParallelResource5_2 {
  end = 200;

  timelines {
    tl1 : cumulative [0.0, 3.0] = 0.0;
    tl2 : cumulative [0.0, 3.0] = 0.0;
  }

  task T1 {
    id 1;
    duration_range [12, 12];
    pre {
      tl1 in [0.0, 2.0];
    }
    inv {
      tl1 in [0.0, 3.0];
    }
    impacts {
      pre {
        tl1 += 1.0;
      }
      post {
        tl1 += -1.0;
      }
    }
  }

  task T2 {
    id 2;
    duration_range [14, 14];
    pre {
      tl2 in [0.0, 2.0];
    }
    inv {
      tl2 in [0.0, 3.0];
    }
    impacts {
      pre {
        tl2 += 1.0;
      }
      post {
        tl2 += -1.0;
      }
    }
  }

  task T3 {
    id 3;
    duration_range [16, 16];
    pre {
      tl1 in [0.0, 2.0];
    }
    inv {
      tl1 in [0.0, 3.0];
    }
    impacts {
      pre {
        tl1 += 1.0;
      }
      post {
        tl1 += -1.0;
      }
    }
  }

  task T4 {
    id 4;
    duration_range [18, 18];
    pre {
      tl2 in [0.0, 2.0];
    }
    inv {
      tl2 in [0.0, 3.0];
    }
    impacts {
      pre {
        tl2 += 1.0;
      }
      post {
        tl2 += -1.0;
      }
    }
  }

  task T5 {
    id 5;
    duration_range [20, 20];
    pre {
      tl1 in [0.0, 2.0];
    }
    inv {
      tl1 in [0.0, 3.0];
    }
    impacts {
      pre {
        tl1 += 1.0;
      }
      post {
        tl1 += -1.0;
      }
    }
  }

}
