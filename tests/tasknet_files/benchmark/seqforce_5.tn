# Generated by: python tools/generate_benchmark.py --output tests/tasknet_files/benchmark/seqforce_5.tn sequential --tasks 5 --use-windows
#
# Sequential Force Benchmark (Resources + Time Windows)
# 
# Configuration:
# - 5 tasks (4 required, 1 optional)
# - 1 timeline (battery)
# - Sequential ordering via BOTH resources AND time windows
# - Variable durations [1, 6]
# - Time horizon: 100
# 
# Design principle:
#   Like seq benchmarks BUT with added temporal constraints
#   Tests scheduler with BOTH resource dependencies AND time windows
# 
# Resource constraints (same as seq):
# - Battery timeline starts at 0
# - T_i requires battery >= 5.0*(i-1)
# - Each task charges battery at +1.0/time
# - Forces T1 → T2 → ... → T5 ordering
# 
# PLUS temporal constraints (added):
# - Each task has start_range and duration_range
# - Windows arranged to prevent overlapping (sequential)
# - duration_range provides scheduling flexibility
# 
# Expected behavior:
# - Tasks execute sequentially (enforced twice: resources + windows)
# - Tests combined resource + temporal reasoning
# - More constrained than seq alone

tasknet SeqForce5 {
  end = 100;

  timelines {
    battery : rate [0.0, 200.0] bounds [0.0, 200.0] = 0.0;
  }

  task T1 {
    id 1;
    duration_range [1, 6];
    start_range [0, 2];
    pre {
      battery in [0.0, 200.0];
    }
    inv {
      battery in [0.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T2 {
    id 2;
    duration_range [1, 6];
    start_range [8, 10];
    pre {
      battery in [5.0, 200.0];
    }
    inv {
      battery in [5.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T3 {
    id 3;
    duration_range [1, 6];
    start_range [16, 18];
    pre {
      battery in [10.0, 200.0];
    }
    inv {
      battery in [10.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T4 {
    id 4;
    duration_range [1, 6];
    start_range [24, 26];
    pre {
      battery in [15.0, 200.0];
    }
    inv {
      battery in [15.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T5 {
    id 5;
    duration_range [1, 6];
    start_range [32, 34];
    pre {
      battery in [20.0, 200.0];
    }
    inv {
      battery in [20.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  properties {
    prop force_t5: eventually active(T5);
  }
}
