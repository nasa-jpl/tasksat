# Generated by: python tools/generate_benchmark.py --output tests/tasknet_files/benchmark/seq_5.tn sequential --tasks 5
#
# Sequential Chain Benchmark (Resource Dependencies)
# 
# Configuration:
# - 5 tasks (4 required, 1 optional)
# - 1 timeline (battery)
# - Sequential chain pattern: T1 → T2 → ... → T5
# - Variable durations [1, 6]
# 
# Expected behavior:
# - Tasks must execute sequentially
# - T_i requires battery >= 5.0*(i-1)
# - Each task charges battery at +1.0/time

tasknet SequentialChain5 {
  end = 50;

  timelines {
    battery : rate [0.0, 200.0] bounds [0.0, 200.0] = 0.0;
  }

  task T1 {
    id 1;
    duration_range [1, 6];
    pre {
      battery in [0.0, 200.0];
    }
    inv {
      battery in [0.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T2 {
    id 2;
    duration_range [1, 6];
    pre {
      battery in [5.0, 200.0];
    }
    inv {
      battery in [5.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T3 {
    id 3;
    duration_range [1, 6];
    pre {
      battery in [10.0, 200.0];
    }
    inv {
      battery in [10.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T4 {
    id 4;
    duration_range [1, 6];
    pre {
      battery in [15.0, 200.0];
    }
    inv {
      battery in [15.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T5 {
    id 5;
    duration_range [1, 6];
    pre {
      battery in [20.0, 200.0];
    }
    inv {
      battery in [20.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  properties {
    prop force_t5: eventually active(T5);
  }
}
