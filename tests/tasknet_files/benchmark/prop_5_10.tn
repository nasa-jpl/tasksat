# Generated by: python tools/generate_benchmark.py --output tests/tasknet_files/benchmark/prop_5_10.tn properties --tasks 5 --properties 10
#
# Property Verification Benchmark
# 
# PURPOSE: Measure the cost of verifying temporal properties
# 
# Configuration:
# - 5 tasks (deliberately simple)
# - 10 temporal properties (the real workload)
# - 2 timelines: tl1 (rate resource), tl2 (state machine)
# - Time horizon: 200
# 
# Design principle:
#   Make scheduling TRIVIAL → isolate property verification cost
# 
#   - Tasks are simple: all identical duration (15), minimal constraints
#   - No forced ordering: tasks can run in any order or parallel
#   - Resources are abundant: tl1 starts at 50, only drops to ~20
#   - SMT solver finds valid schedule quickly (<1 second)
# 
#   The CHALLENGE: verifying 10 temporal properties
# 
# Task design:
# - All tasks: duration_range [15, 15], precondition tl1 >= 10
# - tl1 (rate): starts at 50, tasks drain -0.2/time
#   Worst case: all 5 tasks sequential = 50 - (5×15×0.2) = 35.0 ✓
# - tl2 (state): Each task sets unique state during execution
#   T1: s0 → s1 → s0
#   T2: s0 → s2 → s0
#   T3: s0 → s3 → s0
#   (cycles through s1, s2, s3)
# 
# Property types (10 total, cycling through 5 patterns):
# 
# 1. Safety - Resource bounds: always (tl1 >= 5.0)
#    Checks: tl1 never drops below threshold throughout execution
# 
# 2. Liveness - Task execution: eventually active(Ti)
#    Checks: every task must execute at some point in the schedule
# 
# 3. State invariant: always (tl2 = s0 or tl2 = s1 or tl2 = s2 or tl2 = s3)
#    Checks: state machine never enters invalid state
# 
# 4. Implication - Precondition enforcement: always (active(Ti) -> tl1 >= 10.0)
#    Checks: task preconditions hold whenever task is executing
# 
# 5. State reachability: eventually (tl2 = si)
#    Checks: each state in the state machine is reachable
# 
# How to use these benchmarks:
# 
#   Run and measure total verification time:
#     time python src/smt/tasknet_verifier.py prop_5_10.tn
# 
#   Calculate average time per property:
#     avg_time = total_time / 10
# 
#   Compare scaling across property counts:
#     prop_10_20  → ~X seconds → ~X/20 per property
#     prop_10_50  → ~Y seconds → ~Y/50 per property
#     prop_10_100 → ~Z seconds → ~Z/100 per property
# 
#   Ideal: linear scaling (2x properties = 2x time)
#   Reality: may have overhead from property interactions
# 
# Expected result:
# - SAT (valid schedule exists)
# - Scheduling time: <1 second (trivial problem)
# - Most time: property verification (the interesting metric)
# - Good for benchmarking property verification performance

tasknet PropVerify5_10 {
  end = 200;

  timelines {
    tl1 : rate [0.0, 100.0] bounds [0.0, 100.0] = 50.0;
    tl2 : state(s0, s1, s2, s3) = s0;
  }

  task T1 {
    id 1;
    duration_range [15, 15];
    pre {
      tl1 in [10.0, 100.0];
    }
    impacts {
      pre {
        tl2 = s1;
      }
      maint {
        tl1 +~ -0.2;
      }
      post {
        tl2 = s0;
      }
    }
  }

  task T2 {
    id 2;
    duration_range [15, 15];
    pre {
      tl1 in [10.0, 100.0];
    }
    impacts {
      pre {
        tl2 = s2;
      }
      maint {
        tl1 +~ -0.2;
      }
      post {
        tl2 = s0;
      }
    }
  }

  task T3 {
    id 3;
    duration_range [15, 15];
    pre {
      tl1 in [10.0, 100.0];
    }
    impacts {
      pre {
        tl2 = s3;
      }
      maint {
        tl1 +~ -0.2;
      }
      post {
        tl2 = s0;
      }
    }
  }

  task T4 {
    id 4;
    duration_range [15, 15];
    pre {
      tl1 in [10.0, 100.0];
    }
    impacts {
      pre {
        tl2 = s0;
      }
      maint {
        tl1 +~ -0.2;
      }
      post {
        tl2 = s0;
      }
    }
  }

  task T5 {
    id 5;
    duration_range [15, 15];
    pre {
      tl1 in [10.0, 100.0];
    }
    impacts {
      pre {
        tl2 = s1;
      }
      maint {
        tl1 +~ -0.2;
      }
      post {
        tl2 = s0;
      }
    }
  }

  properties {
    prop safety_1: always (tl1 >= 5.0);
    prop liveness_1: eventually active(T1);
    prop state_safety_3: always (tl2 = s0 or tl2 = s1 or tl2 = s2 or tl2 = s3);
    prop implication_2: always (active(T2) -> tl1 >= 10.0);
    prop eventually_state_0: eventually (tl2 = s0);
    prop safety_6: always (tl1 >= 5.0);
    prop liveness_3: eventually active(T3);
    prop state_safety_8: always (tl2 = s0 or tl2 = s1 or tl2 = s2 or tl2 = s3);
    prop implication_4: always (active(T4) -> tl1 >= 10.0);
    prop eventually_state_1: eventually (tl2 = s1);
  }
}
