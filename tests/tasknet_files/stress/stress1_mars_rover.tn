# STRESS TEST 1: Mars Rover Mission
#
# Performance Result: SAT (satisfiable) - completed in 21 minutes 8 seconds (1263.46s)
# - 20 tasks scheduled successfully
# - 14 timelines (battery, power, CPU, memory, temperature, instruments, etc.)
# - 7 temporal properties (all verified)
# - 1000 time horizon, actual schedule ends at time 204
# - 42 zones generated from task boundaries
#
# Observations:
# - Solver found valid schedule satisfying all constraints
# - ~1 minute per task for this complexity level
# - Battery management worked (charging scheduled, safety maintained)
# - Resource conflicts properly resolved
# - Data collection pipeline successful (collect → buffer → transmit)

tasknet MarsRoverMission {
  end = 1000;

  timelines {
    # Power system
    battery       : rate [0.0, 100.0] bounds [0.0, 100.0] = 100.0;
    solar_charging: state(off, charging) = off;

    # Compute resources
    cpu           : claim [0.0, 100.0] = 0.0;
    memory        : claim [0.0, 16.0] = 0.0;  # GB
    storage       : cumul [0.0, 500.0] bounds [0.0, 500.0] = 500.0;  # GB available

    # Thermal
    core_temp     : rate [0.0, 80.0] bounds [-20.0, 85.0] = 20.0;  # Celsius

    # Mobility
    wheels        : state(parked, driving, turning) = parked;
    position_x    : cumul [-1000.0, 1000.0] bounds [-1000.0, 1000.0] = 0.0;
    position_y    : cumul [-1000.0, 1000.0] bounds [-1000.0, 1000.0] = 0.0;

    # Instruments
    camera_state  : state(off, imaging, processing) = off;
    spectrometer  : state(off, analyzing) = off;
    drill         : state(off, drilling, extracting) = off;

    # Communication
    antenna       : state(stowed, deployed) = stowed;
    data_buffer   : cumul [0.0, 50.0] bounds [0.0, 50.0] = 0.0;  # GB buffered
  }

  # ==== POWER MANAGEMENT TASKS ====

  task solar_charge {
    id 1;
    duration 100;

    pre {
      solar_charging = off;
      battery in [0.0, 95.0];
    }

    impacts {
      pre {
        solar_charging = charging;
      }
      maint {
        battery +~ 0.5;  # Charge at 0.5%/time
      }
      post {
        solar_charging = off;
      }
    }
  }

  # ==== NAVIGATION TASKS ====

  task drive_north_short {
    id 10;
    duration 20;

    pre {
      wheels = parked;
      battery in [30.0, 100.0];
    }

    inv {
      battery in [20.0, 100.0];
      core_temp in [-20.0, 75.0];
    }

    impacts {
      pre {
        wheels = driving;
      }
      maint {
        cpu += 20.0;
        battery +~ -0.8;
        core_temp +~ 0.3;
        position_y += 10.0;
      }
      post {
        wheels = parked;
      }
    }
  }

  task drive_north_medium {
    id 11;
    duration 50;

    pre {
      wheels = parked;
      battery in [40.0, 100.0];
    }

    inv {
      battery in [25.0, 100.0];
    }

    impacts {
      pre { wheels = driving; }
      maint {
        cpu += 20.0;
        battery +~ -0.7;
        core_temp +~ 0.25;
        position_y += 25.0;
      }
      post { wheels = parked; }
    }
  }

  task drive_east_short {
    id 12;
    duration 20;

    pre {
      wheels = parked;
      battery in [30.0, 100.0];
    }

    inv {
      battery in [20.0, 100.0];
    }

    impacts {
      pre { wheels = driving; }
      maint {
        cpu += 20.0;
        battery +~ -0.8;
        core_temp +~ 0.3;
        position_x += 10.0;
      }
      post { wheels = parked; }
    }
  }

  task drive_west_short {
    id 13;
    duration 20;

    pre {
      wheels = parked;
      battery in [30.0, 100.0];
    }

    inv {
      battery in [20.0, 100.0];
    }

    impacts {
      pre { wheels = driving; }
      maint {
        cpu += 20.0;
        battery +~ -0.8;
        core_temp +~ 0.3;
        position_x += -10.0;
      }
      post { wheels = parked; }
    }
  }

  # ==== IMAGING TASKS ====

  task capture_panorama {
    id 20;
    duration 30;

    pre {
      camera_state = off;
      wheels = parked;
      battery in [25.0, 100.0];
      storage in [5.0, 500.0];
    }

    inv {
      battery in [15.0, 100.0];
    }

    impacts {
      pre {
        camera_state = imaging;
      }
      maint {
        cpu += 30.0;
        memory += 2.0;
        battery +~ -0.4;
        core_temp +~ 0.2;
      }
      post {
        camera_state = processing;
        storage += -3.0;
        data_buffer += 3.0;
      }
    }
  }

  task process_images {
    id 21;
    duration 40;

    pre {
      camera_state = processing;
      battery in [20.0, 100.0];
    }

    inv {
      battery in [15.0, 100.0];
    }

    impacts {
      maint {
        cpu += 60.0;
        memory += 4.0;
        battery +~ -0.3;
        core_temp +~ 0.4;
      }
      post {
        camera_state = off;
      }
    }
  }

  task capture_target_1 {
    id 22;
    duration 15;

    pre {
      camera_state = off;
      wheels = parked;
      battery in [20.0, 100.0];
      storage in [2.0, 500.0];
    }

    impacts {
      pre { camera_state = imaging; }
      maint {
        cpu += 25.0;
        memory += 1.5;
        battery +~ -0.3;
      }
      post {
        camera_state = off;
        storage += -1.5;
        data_buffer += 1.5;
      }
    }
  }

  task capture_target_2 {
    id 23;
    duration 15;

    pre {
      camera_state = off;
      wheels = parked;
      battery in [20.0, 100.0];
      storage in [2.0, 500.0];
    }

    impacts {
      pre { camera_state = imaging; }
      maint {
        cpu += 25.0;
        memory += 1.5;
        battery +~ -0.3;
      }
      post {
        camera_state = off;
        storage += -1.5;
        data_buffer += 1.5;
      }
    }
  }

  # ==== SPECTROMETRY TASKS ====

  task spectral_analysis_rock {
    id 30;
    duration 45;

    pre {
      spectrometer = off;
      wheels = parked;
      battery in [30.0, 100.0];
      storage in [4.0, 500.0];
    }

    inv {
      battery in [20.0, 100.0];
      core_temp in [-20.0, 75.0];
    }

    impacts {
      pre { spectrometer = analyzing; }
      maint {
        cpu += 40.0;
        memory += 3.0;
        battery +~ -0.5;
        core_temp +~ 0.3;
      }
      post {
        spectrometer = off;
        storage += -3.0;
        data_buffer += 3.0;
      }
    }
  }

  task spectral_analysis_soil {
    id 31;
    duration 40;

    pre {
      spectrometer = off;
      wheels = parked;
      battery in [28.0, 100.0];
      storage in [3.5, 500.0];
    }

    inv {
      battery in [18.0, 100.0];
    }

    impacts {
      pre { spectrometer = analyzing; }
      maint {
        cpu += 40.0;
        memory += 3.0;
        battery +~ -0.45;
        core_temp +~ 0.28;
      }
      post {
        spectrometer = off;
        storage += -2.8;
        data_buffer += 2.8;
      }
    }
  }

  # ==== DRILLING TASKS ====

  task drill_sample {
    id 40;
    duration 60;

    pre {
      drill = off;
      wheels = parked;
      battery in [40.0, 100.0];
    }

    inv {
      battery in [25.0, 100.0];
      core_temp in [-20.0, 78.0];
    }

    impacts {
      pre { drill = drilling; }
      maint {
        cpu += 50.0;
        battery +~ -0.6;
        core_temp +~ 0.4;
      }
      post {
        drill = extracting;
      }
    }
  }

  task extract_sample {
    id 41;
    duration 30;

    pre {
      drill = extracting;
      battery in [25.0, 100.0];
      storage in [5.0, 500.0];
    }

    inv {
      battery in [18.0, 100.0];
    }

    impacts {
      maint {
        cpu += 30.0;
        battery +~ -0.4;
        core_temp +~ 0.25;
      }
      post {
        drill = off;
        storage += -4.0;
        data_buffer += 4.0;
      }
    }
  }

  # ==== COMMUNICATION TASKS ====

  task deploy_antenna {
    id 50;
    duration 10;

    pre {
      antenna = stowed;
      wheels = parked;
      battery in [15.0, 100.0];
    }

    impacts {
      maint {
        cpu += 15.0;
        battery +~ -0.2;
      }
      post {
        antenna = deployed;
      }
    }
  }

  task transmit_data {
    id 51;
    duration 80;

    pre {
      antenna = deployed;
      data_buffer in [5.0, 50.0];
      battery in [35.0, 100.0];
    }

    inv {
      battery in [25.0, 100.0];
      core_temp in [-20.0, 80.0];
    }

    after deploy_antenna;

    impacts {
      maint {
        cpu += 45.0;
        memory += 2.0;
        battery +~ -0.5;
        core_temp +~ 0.35;
        data_buffer += -10.0;  # Transmit 10GB total
      }
    }
  }

  task stow_antenna {
    id 52;
    duration 10;

    pre {
      antenna = deployed;
      battery in [12.0, 100.0];
    }

    after transmit_data;

    impacts {
      maint {
        cpu += 15.0;
        battery +~ -0.2;
      }
      post {
        antenna = stowed;
      }
    }
  }

  # ==== THERMAL MANAGEMENT ====

  task active_cooling {
    id 60;
    duration 40;

    pre {
      core_temp in [60.0, 85.0];
      battery in [20.0, 100.0];
    }

    inv {
      battery in [15.0, 100.0];
    }

    impacts {
      maint {
        cpu += 20.0;
        battery +~ -0.4;
        core_temp +~ -0.8;  # Cool down
      }
    }
  }

  # ==== ADDITIONAL SCIENCE TASKS ====

  task atmospheric_sampling {
    id 70;
    duration 25;

    pre {
      wheels = parked;
      battery in [22.0, 100.0];
      storage in [2.5, 500.0];
    }

    inv {
      battery in [16.0, 100.0];
    }

    impacts {
      maint {
        cpu += 35.0;
        memory += 2.5;
        battery +~ -0.35;
        core_temp +~ 0.22;
      }
      post {
        storage += -2.0;
        data_buffer += 2.0;
      }
    }
  }

  task magnetic_field_scan {
    id 71;
    duration 35;

    pre {
      wheels = parked;
      battery in [25.0, 100.0];
      storage in [3.0, 500.0];
    }

    inv {
      battery in [18.0, 100.0];
    }

    impacts {
      maint {
        cpu += 30.0;
        memory += 2.0;
        battery +~ -0.38;
        core_temp +~ 0.24;
      }
      post {
        storage += -2.5;
        data_buffer += 2.5;
      }
    }
  }

  task seismic_monitoring {
    id 72;
    duration 120;

    pre {
      wheels = parked;
      battery in [45.0, 100.0];
      storage in [8.0, 500.0];
    }

    inv {
      battery in [30.0, 100.0];
      wheels = parked;
    }

    impacts {
      maint {
        cpu += 15.0;
        memory += 1.0;
        battery +~ -0.15;
        core_temp +~ 0.08;
      }
      post {
        storage += -6.0;
        data_buffer += 6.0;
      }
    }
  }

  properties {
    # Safety properties
    prop battery_safe: always (battery >= 15.0);
    prop temp_safe: always (core_temp <= 80.0);
    prop no_move_while_drilling: always (drill = drilling -> wheels = parked);
    prop no_move_while_imaging: always (camera_state = imaging -> wheels = parked);

    # Mission objectives
    prop must_drill: eventually (drill = drilling);
    prop must_transmit: eventually (antenna = deployed);
    prop data_collected: eventually (data_buffer >= 10.0);
  }
}
