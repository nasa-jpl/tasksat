# STRESS TEST 5: Sequential Task Chain
#
# Performance Result: TIMEOUT - exceeded 2 hours without completing
# - 30 tasks (21 required, 9 optional)
# - 7 timelines
# - 1 temporal property
# - 300 time horizon
#
# The solver did not complete within reasonable time limits (>2 hours).
# This demonstrates non-linear scaling - while stress1 (20 tasks) completed
# in 21 minutes, adding 10 more tasks with sequential dependencies caused
# exponential blowup in search space.
#
# Design: Tasks naturally ordered by battery charging requirements
# - N=30 tasks (T1, T2, ..., T30)
# - Temporal constraint: eventually T30 must be active
# - Battery starts at 0
# - Task Ti requires battery >= (i-1)*K where K=5
# - Each task charges battery at rate +1.0 during execution
# - Duration range: [1, K+1] = [1, 6] time units
# - Some tasks are optional (every 3rd task)
#
# Expected behavior:
# - Tasks naturally schedule in sequence T1 → T2 → ... → T30
# - Each task charges enough battery for the next task's precondition
# - Optional tasks may be skipped if they don't help reach T30
#
# This tests:
# - Constraint propagation through resource dependencies
# - Optimization with mixed required/optional tasks
# - Long sequential chains

tasknet SequentialChain {
  end = 300;

  timelines {
    battery : rate [0.0, 200.0] bounds [0.0, 200.0] = 0.0;
  }

  # Required tasks with increasing battery requirements

  task T1 {
    id 1;
    duration_range [1, 6];
    pre {
      battery in [0.0, 200.0];  # Can start immediately
    }
    inv {
      battery in [0.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;  # Charge at +1.0/time
      }
    }
  }

  task T2 {
    id 2;
    duration_range [1, 6];
    pre {
      battery in [5.0, 200.0];  # Needs 1*K = 5
    }
    inv {
      battery in [5.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T3 {
    id 3;
    duration_range [1, 6];
    pre {
      battery in [10.0, 200.0];  # Needs 2*K = 10
    }
    inv {
      battery in [10.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T4 {
