# STRESS TEST 7: Sequential Task Chain (15 tasks)
#
# Performance Results:
# - --mode satisfy: SAT in 2 minutes 40 seconds
# - --mode optimize: TIMEOUT (exceeded 28 minutes without completing)
#
# Test configuration:
# - 15 tasks (11 required, 4 optional)
# - 1 timeline (battery)
# - 1 temporal property
# - 150 time horizon
#
# Key insight: The problem is SATISFIABLE and can be solved quickly in satisfy mode,
# but becomes intractable when optimization is enabled. This demonstrates that the
# sequential chain pattern difficulty is primarily in the OPTIMIZATION phase, not
# in finding any satisfying solution.
#
# The satisfy mode solution:
# - Scheduled 13/15 tasks (excluded optional T12, T15)
# - Makespan: 149 time units
# - Battery charged sequentially as designed
#
# Scaling results for sequential chain pattern (optimize mode):
# - stress7 (15 tasks): TIMEOUT at 28 minutes (but SAT in 2:40 with satisfy mode)
# - stress6 (20 tasks): TIMEOUT at 15 minutes
# - stress5 (30 tasks): TIMEOUT at 2 hours
#
# Conclusion: Optimization with sequential dependencies is the hard problem.
#
# Design: Tasks naturally ordered by battery charging requirements
# - N=15 tasks (T1, T2, ..., T15)
# - Temporal constraint: eventually T15 must be active
# - Battery starts at 0
# - Task Ti requires battery >= (i-1)*K where K=5
# - Each task charges battery at rate +1.0 during execution
# - Duration range: [1, K+1] = [1, 6] time units
# - Some tasks are optional (every 3rd task: T3, T6, T9, T12, T15)
#
# Expected behavior:
# - Tasks naturally schedule in sequence T1 → T2 → ... → T15
# - Each task charges enough battery for the next task's precondition
# - Optional tasks may be skipped if they don't help reach T15
#
# This tests:
# - Finding the threshold where sequential chains become solvable
# - Compare to: stress6 (20 tasks, TIMEOUT at 15 min) and stress5 (30 tasks, TIMEOUT at 2 hours)

tasknet SequentialChain15 {
  end = 150;

  timelines {
    battery : rate [0.0, 200.0] bounds [0.0, 200.0] = 0.0;
  }

  # Required tasks with increasing battery requirements

  task T1 {
    id 1;
    duration_range [1, 6];
    pre {
      battery in [0.0, 200.0];  # Can start immediately
    }
    inv {
      battery in [0.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;  # Charge at +1.0/time
      }
    }
  }

  task T2 {
    id 2;
    duration_range [1, 6];
    pre {
      battery in [5.0, 200.0];  # Needs 1*K = 5
    }
    inv {
      battery in [5.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T3 {
    id 3;
    duration_range [1, 6];
    pre {
      battery in [10.0, 200.0];  # Needs 2*K = 10
    }
    inv {
      battery in [10.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T4 {
    id 4;
    duration_range [1, 6];
    pre {
      battery in [15.0, 200.0];  # Needs 3*K = 15
    }
    inv {
      battery in [15.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T5 {
    id 5;
    duration_range [1, 6];
    pre {
      battery in [20.0, 200.0];  # Needs 4*K = 20
    }
    inv {
      battery in [20.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T6 {
    id 6;
    duration_range [1, 6];
    pre {
      battery in [25.0, 200.0];  # Needs 5*K = 25
    }
    inv {
      battery in [25.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T7 {
    id 7;
    duration_range [1, 6];
    pre {
      battery in [30.0, 200.0];
    }
    inv {
      battery in [30.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T8 {
    id 8;
    duration_range [1, 6];
    pre {
      battery in [35.0, 200.0];
    }
    inv {
      battery in [35.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T9 {
    id 9;
    duration_range [1, 6];
    pre {
      battery in [40.0, 200.0];
    }
    inv {
      battery in [40.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T10 {
    id 10;
    duration_range [1, 6];
    pre {
      battery in [45.0, 200.0];
    }
    inv {
      battery in [45.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T11 {
    id 11;
    duration_range [1, 6];
    pre {
      battery in [50.0, 200.0];
    }
    inv {
      battery in [50.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T12 {
    id 12;
    duration_range [1, 6];
    pre {
      battery in [55.0, 200.0];
    }
    inv {
      battery in [55.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T13 {
    id 13;
    duration_range [1, 6];
    pre {
      battery in [60.0, 200.0];
    }
    inv {
      battery in [60.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  task T14 {
    id 14;
    duration_range [1, 6];
    pre {
      battery in [65.0, 200.0];
    }
    inv {
      battery in [65.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  optional task T15 {
    id 15;
    duration_range [1, 6];
    pre {
      battery in [70.0, 200.0];
    }
    inv {
      battery in [70.0, 200.0];
    }
    impacts {
      maint {
        battery +~ 1.0;
      }
    }
  }

  # Temporal constraint: T15 must eventually execute
  constraints {
    prop force_t15: eventually active(T15);
  }
}
