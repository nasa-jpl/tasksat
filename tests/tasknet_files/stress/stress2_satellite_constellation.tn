# STRESS TEST 2: Satellite Constellation
#
# Performance Result: UNSAT (unsatisfiable) - completed in 1.48 seconds
# - 30 tasks across 3 satellites
# - 33 timelines (battery, thermal, compute, storage, instruments, etc.)
# - 9 temporal properties
# - 2000 time horizon
#
# The constraints are too tight - Z3 quickly determined no valid schedule exists.
# Likely causes:
# - Battery constraints too aggressive across 3 satellites
# - Ground station visibility conflicts (only 1 sat visible per station at a time)
# - Downlink exclusivity (only 1 sat can transmit at once)
# - Insufficient charging time to support all power-hungry operations
#
# This demonstrates efficient constraint conflict detection by the SMT solver.

tasknet SatelliteConstellation {
  end = 2000;

  timelines {
    # Power systems (3 satellites)
    sat1_battery  : rate [0.0, 100.0] bounds [0.0, 100.0] = 80.0;
    sat2_battery  : rate [0.0, 100.0] bounds [0.0, 100.0] = 80.0;
    sat3_battery  : rate [0.0, 100.0] bounds [0.0, 100.0] = 80.0;

    # Solar panel states
    sat1_solar    : state(stowed, deployed, tracking) = deployed;
    sat2_solar    : state(stowed, deployed, tracking) = deployed;
    sat3_solar    : state(stowed, deployed, tracking) = deployed;

    # Compute resources
    sat1_cpu      : claim [0.0, 100.0] = 0.0;
    sat2_cpu      : claim [0.0, 100.0] = 0.0;
    sat3_cpu      : claim [0.0, 100.0] = 0.0;

    sat1_memory   : claim [0.0, 32.0] = 0.0;
    sat2_memory   : claim [0.0, 32.0] = 0.0;
    sat3_memory   : claim [0.0, 32.0] = 0.0;

    # Data storage
    sat1_storage  : cumul [0.0, 1000.0] bounds [0.0, 1000.0] = 1000.0;
    sat2_storage  : cumul [0.0, 1000.0] bounds [0.0, 1000.0] = 1000.0;
    sat3_storage  : cumul [0.0, 1000.0] bounds [0.0, 1000.0] = 1000.0;

    # Thermal
    sat1_temp     : rate [-50.0, 100.0] bounds [-50.0, 85.0] = 20.0;
    sat2_temp     : rate [-50.0, 100.0] bounds [-50.0, 85.0] = 20.0;
    sat3_temp     : rate [-50.0, 100.0] bounds [-50.0, 85.0] = 20.0;

    # Attitude control
    sat1_attitude : state(0, 1, 2, 3, 4) = 0;  # Pointing modes
    sat2_attitude : state(0, 1, 2, 3, 4) = 0;
    sat3_attitude : state(0, 1, 2, 3, 4) = 0;

    # Instruments
    sat1_camera   : state(off, imaging, downloading) = off;
    sat2_camera   : state(off, imaging, downloading) = off;
    sat3_camera   : state(off, imaging, downloading) = off;

    # Communication
    downlink_busy : atomic = false;
    uplink_busy   : atomic = false;

    # Ground station visibility
    gs1_visible   : state(0, 1, 2, 3) = 0;  # Which sat is visible
    gs2_visible   : state(0, 1, 2, 3) = 0;

    # Mission data
    science_data  : cumul [0.0, 5000.0] bounds [0.0, 5000.0] = 0.0;
    priority_targets: cumul [0.0, 50.0] bounds [0.0, 50.0] = 50.0;
  }

  # ==== SATELLITE 1 TASKS ====

  task sat1_solar_charge {
    id 101;
    duration 150;
    pre {
      sat1_solar = deployed;
      sat1_battery in [0.0, 90.0];
    }
    impacts {
      pre { sat1_solar = tracking; }
      maint { sat1_battery +~ 0.3; }
      post { sat1_solar = deployed; }
    }
  }

  task sat1_imaging_target_a {
    id 102;
    duration 45;
    pre {
      sat1_camera = off;
      sat1_attitude = 0;
      sat1_battery in [40.0, 100.0];
      sat1_storage in [50.0, 1000.0];
      priority_targets in [1.0, 50.0];
    }
    inv {
      sat1_battery in [30.0, 100.0];
      sat1_temp in [-50.0, 75.0];
    }
    impacts {
      pre {
        sat1_camera = imaging;
        sat1_attitude = 1;
      }
      maint {
        sat1_cpu += 50.0;
        sat1_memory += 8.0;
        sat1_battery +~ -0.6;
        sat1_temp +~ 0.4;
      }
      post {
        sat1_camera = off;
        sat1_attitude = 0;
        sat1_storage += -40.0;
        science_data += 40.0;
        priority_targets += -1.0;
      }
    }
  }

  task sat1_imaging_target_b {
    id 103;
    duration 40;
    pre {
      sat1_camera = off;
      sat1_attitude = 0;
      sat1_battery in [38.0, 100.0];
      sat1_storage in [45.0, 1000.0];
      priority_targets in [1.0, 50.0];
    }
    inv {
      sat1_battery in [28.0, 100.0];
    }
    impacts {
      pre {
        sat1_camera = imaging;
        sat1_attitude = 2;
      }
      maint {
        sat1_cpu += 48.0;
        sat1_memory += 7.5;
        sat1_battery +~ -0.55;
        sat1_temp +~ 0.38;
      }
      post {
        sat1_camera = off;
        sat1_attitude = 0;
        sat1_storage += -35.0;
        science_data += 35.0;
        priority_targets += -1.0;
      }
    }
  }

  task sat1_downlink_gs1 {
    id 104;
    duration 80;
    pre {
      gs1_visible = 1;
      downlink_busy = false;
      sat1_storage in [0.0, 950.0];
      sat1_battery in [45.0, 100.0];
    }
    inv {
      sat1_battery in [35.0, 100.0];
      downlink_busy = true;
    }
    impacts {
      pre {
        sat1_camera = downloading;
        sat1_attitude = 3;
        downlink_busy = true;
      }
      maint {
        sat1_cpu += 40.0;
        sat1_memory += 4.0;
        sat1_battery +~ -0.45;
        sat1_temp +~ 0.3;
        sat1_storage += 100.0;
      }
      post {
        sat1_camera = off;
        sat1_attitude = 0;
        downlink_busy = false;
      }
    }
  }

  task sat1_orbit_adjust {
    id 105;
    duration 30;
    pre {
      sat1_attitude = 0;
      sat1_battery in [35.0, 100.0];
    }
    inv {
      sat1_battery in [25.0, 100.0];
    }
    impacts {
      pre { sat1_attitude = 4; }
      maint {
        sat1_cpu += 60.0;
        sat1_battery +~ -0.7;
        sat1_temp +~ 0.5;
      }
      post { sat1_attitude = 0; }
    }
  }

  # ==== SATELLITE 2 TASKS ====

  task sat2_solar_charge {
    id 201;
    duration 150;
    pre {
      sat2_solar = deployed;
      sat2_battery in [0.0, 90.0];
    }
    impacts {
      pre { sat2_solar = tracking; }
      maint { sat2_battery +~ 0.3; }
      post { sat2_solar = deployed; }
    }
  }

  task sat2_imaging_target_c {
    id 202;
    duration 50;
    pre {
      sat2_camera = off;
      sat2_attitude = 0;
      sat2_battery in [42.0, 100.0];
      sat2_storage in [55.0, 1000.0];
      priority_targets in [1.0, 50.0];
    }
    inv {
      sat2_battery in [32.0, 100.0];
      sat2_temp in [-50.0, 75.0];
    }
    impacts {
      pre {
        sat2_camera = imaging;
        sat2_attitude = 1;
      }
      maint {
        sat2_cpu += 52.0;
        sat2_memory += 8.5;
        sat2_battery +~ -0.62;
        sat2_temp +~ 0.42;
      }
      post {
        sat2_camera = off;
        sat2_attitude = 0;
        sat2_storage += -45.0;
        science_data += 45.0;
        priority_targets += -1.0;
      }
    }
  }

  task sat2_imaging_target_d {
    id 203;
    duration 35;
    pre {
      sat2_camera = off;
      sat2_attitude = 0;
      sat2_battery in [36.0, 100.0];
      sat2_storage in [40.0, 1000.0];
      priority_targets in [1.0, 50.0];
    }
    inv {
      sat2_battery in [26.0, 100.0];
    }
    impacts {
      pre {
        sat2_camera = imaging;
        sat2_attitude = 2;
      }
      maint {
        sat2_cpu += 46.0;
        sat2_memory += 7.0;
        sat2_battery +~ -0.5;
        sat2_temp +~ 0.35;
      }
      post {
        sat2_camera = off;
        sat2_attitude = 0;
        sat2_storage += -30.0;
        science_data += 30.0;
        priority_targets += -1.0;
      }
    }
  }

  task sat2_downlink_gs2 {
    id 204;
    duration 85;
    pre {
      gs2_visible = 2;
      downlink_busy = false;
      sat2_storage in [0.0, 950.0];
      sat2_battery in [46.0, 100.0];
    }
    inv {
      sat2_battery in [36.0, 100.0];
      downlink_busy = true;
    }
    impacts {
      pre {
        sat2_camera = downloading;
        sat2_attitude = 3;
        downlink_busy = true;
      }
      maint {
        sat2_cpu += 42.0;
        sat2_memory += 4.5;
        sat2_battery +~ -0.47;
        sat2_temp +~ 0.32;
        sat2_storage += 105.0;
      }
      post {
        sat2_camera = off;
        sat2_attitude = 0;
        downlink_busy = false;
      }
    }
  }

  task sat2_orbit_adjust {
    id 205;
    duration 28;
    pre {
      sat2_attitude = 0;
      sat2_battery in [33.0, 100.0];
    }
    inv {
      sat2_battery in [23.0, 100.0];
    }
    impacts {
      pre { sat2_attitude = 4; }
      maint {
        sat2_cpu += 58.0;
        sat2_battery +~ -0.68;
        sat2_temp +~ 0.48;
      }
      post { sat2_attitude = 0; }
    }
  }

  # ==== SATELLITE 3 TASKS ====

  task sat3_solar_charge {
    id 301;
    duration 150;
    pre {
      sat3_solar = deployed;
      sat3_battery in [0.0, 90.0];
    }
    impacts {
      pre { sat3_solar = tracking; }
      maint { sat3_battery +~ 0.3; }
      post { sat3_solar = deployed; }
    }
  }

  task sat3_imaging_target_e {
    id 302;
    duration 42;
    pre {
      sat3_camera = off;
      sat3_attitude = 0;
      sat3_battery in [39.0, 100.0];
      sat3_storage in [48.0, 1000.0];
      priority_targets in [1.0, 50.0];
    }
    inv {
      sat3_battery in [29.0, 100.0];
      sat3_temp in [-50.0, 75.0];
    }
    impacts {
      pre {
        sat3_camera = imaging;
        sat3_attitude = 1;
      }
      maint {
        sat3_cpu += 49.0;
        sat3_memory += 7.8;
        sat3_battery +~ -0.58;
        sat3_temp +~ 0.39;
      }
      post {
        sat3_camera = off;
        sat3_attitude = 0;
        sat3_storage += -38.0;
        science_data += 38.0;
        priority_targets += -1.0;
      }
    }
  }

  task sat3_imaging_target_f {
    id 303;
    duration 38;
    pre {
      sat3_camera = off;
      sat3_attitude = 0;
      sat3_battery in [37.0, 100.0];
      sat3_storage in [43.0, 1000.0];
      priority_targets in [1.0, 50.0];
    }
    inv {
      sat3_battery in [27.0, 100.0];
    }
    impacts {
      pre {
        sat3_camera = imaging;
        sat3_attitude = 2;
      }
      maint {
        sat3_cpu += 47.0;
        sat3_memory += 7.2;
        sat3_battery +~ -0.52;
        sat3_temp +~ 0.36;
      }
      post {
        sat3_camera = off;
        sat3_attitude = 0;
        sat3_storage += -33.0;
        science_data += 33.0;
        priority_targets += -1.0;
      }
    }
  }

  task sat3_downlink_gs1 {
    id 304;
    duration 75;
    pre {
      gs1_visible = 3;
      downlink_busy = false;
      sat3_storage in [0.0, 950.0];
      sat3_battery in [44.0, 100.0];
    }
    inv {
      sat3_battery in [34.0, 100.0];
      downlink_busy = true;
    }
    impacts {
      pre {
        sat3_camera = downloading;
        sat3_attitude = 3;
        downlink_busy = true;
      }
      maint {
        sat3_cpu += 38.0;
        sat3_memory += 3.8;
        sat3_battery +~ -0.42;
        sat3_temp +~ 0.28;
        sat3_storage += 95.0;
      }
      post {
        sat3_camera = off;
        sat3_attitude = 0;
        downlink_busy = false;
      }
    }
  }

  task sat3_orbit_adjust {
    id 305;
    duration 32;
    pre {
      sat3_attitude = 0;
      sat3_battery in [36.0, 100.0];
    }
    inv {
      sat3_battery in [26.0, 100.0];
    }
    impacts {
      pre { sat3_attitude = 4; }
      maint {
        sat3_cpu += 62.0;
        sat3_battery +~ -0.72;
        sat3_temp +~ 0.52;
      }
      post { sat3_attitude = 0; }
    }
  }

  # ==== COORDINATION TASKS ====

  task gs1_tracking_sat1 {
    id 401;
    duration 120;
    pre { gs1_visible = 0; }
    impacts {
      pre { gs1_visible = 1; }
      post { gs1_visible = 0; }
    }
  }

  task gs1_tracking_sat3 {
    id 402;
    duration 120;
    pre { gs1_visible = 0; }
    impacts {
      pre { gs1_visible = 3; }
      post { gs1_visible = 0; }
    }
  }

  task gs2_tracking_sat2 {
    id 403;
    duration 120;
    pre { gs2_visible = 0; }
    impacts {
      pre { gs2_visible = 2; }
      post { gs2_visible = 0; }
    }
  }

  # ==== MAINTENANCE TASKS ====

  task sat1_thermal_control {
    id 501;
    duration 25;
    pre {
      sat1_temp in [65.0, 85.0];
      sat1_battery in [25.0, 100.0];
    }
    inv {
      sat1_battery in [20.0, 100.0];
    }
    impacts {
      maint {
        sat1_cpu += 25.0;
        sat1_battery +~ -0.3;
        sat1_temp +~ -1.2;
      }
    }
  }

  task sat2_thermal_control {
    id 502;
    duration 25;
    pre {
      sat2_temp in [65.0, 85.0];
      sat2_battery in [25.0, 100.0];
    }
    inv {
      sat2_battery in [20.0, 100.0];
    }
    impacts {
      maint {
        sat2_cpu += 25.0;
        sat2_battery +~ -0.3;
        sat2_temp +~ -1.2;
      }
    }
  }

  task sat3_thermal_control {
    id 503;
    duration 25;
    pre {
      sat3_temp in [65.0, 85.0];
      sat3_battery in [25.0, 100.0];
    }
    inv {
      sat3_battery in [20.0, 100.0];
    }
    impacts {
      maint {
        sat3_cpu += 25.0;
        sat3_battery +~ -0.3;
        sat3_temp +~ -1.2;
      }
    }
  }

  properties {
    # Safety properties
    prop sat1_battery_safe: always (sat1_battery >= 20.0);
    prop sat2_battery_safe: always (sat2_battery >= 20.0);
    prop sat3_battery_safe: always (sat3_battery >= 20.0);

    prop sat1_temp_safe: always (sat1_temp <= 80.0);
    prop sat2_temp_safe: always (sat2_temp <= 80.0);
    prop sat3_temp_safe: always (sat3_temp <= 80.0);

    # Communication exclusivity
    prop downlink_exclusive: always (downlink_busy = true ->
      (sat1_camera = downloading or sat2_camera = downloading or sat3_camera = downloading));

    # Mission objectives
    prop science_collected: eventually (science_data >= 100.0);
    prop targets_covered: eventually (priority_targets <= 45.0);
  }
}
